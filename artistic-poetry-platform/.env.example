# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Admin credentials are now stored securely in Supabase database!
# No need for VITE_ADMIN_USERNAME or VITE_ADMIN_PASSWORD
# See SECURITY-SETUP.md for instructions
